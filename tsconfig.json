{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    /* JavaScript support (no .ts files — JS only) */
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    /* Strictness — practical level for existing JS codebase */
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "types": ["jest", "node"],

    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Source */
    "baseUrl": ".",
    "paths": {},
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "seeds",
    "node_modules/@jest/environment",
    "prisma"
  ]
}
