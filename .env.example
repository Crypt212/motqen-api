# Environment
NODE_ENV=development

# Backend Port
PORT=3001

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://postgres.svcnfzfbcarrrdxshltl:2L8Got71HHpsLTjh@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?pgbouncer=true
DB_MAX_CONNECTIONS=10
DB_SSL=false

# ===========================================
# Redis
# ===========================================
REDIS_URL=rediss://default:AVhbAAIncDE2ODkyNDZiMmFhMGI0ZDYzOTBlYWE0MDc3MjhkMDg3M3AxMjI2MTk@desired-shiner-22619.upstash.io:6379
REDIS_TTL=3600

# ===========================================
# JWT Tokens
# ===========================================
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_LOGIN_SECRET=your-login-secret-key-min-32-chars
JWT_LOGIN_EXPIRES_IN=7d
JWT_REGISTER_SECRET=your-register-secret-key-min-32-chars
JWT_REGISTER_EXPIRES_IN=7d

# ===========================================
# API
# ===========================================
API_BASE_URL=http://localhost:3001/api/v1
API_VERSION=v1

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_SENSITIVE_WINDOW_MS=900000
RATE_LIMIT_SENSITIVE_MAX=10

# ===========================================
# Logging
# ===========================================
LOGGING_LEVEL=info
ENABLE_FILE_LOGS=true

# ===========================================
# Cloudinary (Image Upload)
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# WhatsApp API
# ===========================================
WHATSAPP_API_KEY=your-whatsapp-api-key

# ===========================================
# OTP Configuration
# ===========================================
OTP_EXPIRES_IN=900
OTP_COOLDOWN_CONSTANT=60

# ===========================================
# Twilio (SMS)
# ===========================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VIRTUAL_NUMBER=+1234567890
