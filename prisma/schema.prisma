generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  isRevoked  Boolean  @default(false)
  deviceId   String
  ipAddress  String?
  userAgent  String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id              String        @id @default(uuid())
  phoneNumber     String        @unique
  firstName       String
  middleName      String
  lastName        String
  governmentId    String?
  cityId          String?
  profileImageUrl String?
  status          AccountStatus @default(ACTIVE)
  role            Role          @default(USER)
  lastSeenAt      DateTime?

  government          Government?               @relation(fields: [governmentId], references: [id], onDelete: Cascade)
  city                City?                     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  sessions            Session[]
  workerProfile       WorkerProfile?
  clientProfile       ClientProfile?
  workerConversations Conversation[]            @relation("WorkerConversations")
  clientConversations Conversation[]            @relation("ClientConversations")
  conversations       ConversationParticipant[]
  sentMessages        Message[]

  @@map("users")
}

model ClientProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  address      String
  addressNotes String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model WorkerProfile {
  id                String  @id @default(uuid())
  userId            String  @unique
  experienceYears   Int
  isInTeam          Boolean
  acceptsUrgentJobs Boolean
  isApproved        Boolean @default(false)

  portfolio             PortfolioProject[]
  verification          WorkerVerification?
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chosenSpecializations ChosenSpecialization[]
  governments           GovernmentForWorkers[]

  @@map("worker_profiles")
}

model WorkerVerification {
  id                     String             @id @default(uuid())
  workerProfileId        String             @unique
  idWithPersonalImageUrl String
  idDocumentUrl          String
  status                 VerificationStatus @default(PENDING)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  reason                 String?

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

model PortfolioProject {
  id              String  @id @default(uuid())
  workerProfileId String
  description     String?

  projectImages ProjectImage[]
  workerProfile WorkerProfile  @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
}

model ProjectImage {
  id        String @id @default(uuid())
  projectId String
  imageUrl  String

  project PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChosenSpecialization {
  workerProfileId     String
  subSpecializationId String @unique
  specializationId    String

  tasks             ChosenSpecializationTask[]
  workerProfile     WorkerProfile              @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  subSpecialization SubSpecialization          @relation(fields: [subSpecializationId], references: [id], onDelete: Cascade)
  specialization    Specialization             @relation(fields: [specializationId], references: [id])

  @@id([workerProfileId, subSpecializationId])
  @@map("chosen_specializations")
}

model ChosenSpecializationTask {
  taskId              String
  subSpecializationId String

  task                 Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  chosenSpecialization ChosenSpecialization @relation(fields: [subSpecializationId], references: [subSpecializationId], onDelete: Cascade)

  @@id([taskId, subSpecializationId])
}

model Task {
  id String @id @default(uuid())

  title String


  specializations ChosenSpecializationTask[]
}

model Specialization {
  id   String @id @default(uuid())
  name String

  subSpecializations SubSpecialization[]
  choosingWorkers    ChosenSpecialization[]

  @@index([name])
  @@map("specializations")
}

model SubSpecialization {
  id                   String @id @default(uuid())
  name                 String
  mainSpecializationId String

  choosingWorkers           ChosenSpecialization[]
  mainSpecialization        Specialization             @relation(fields: [mainSpecializationId], references: [id], onDelete: Cascade)

  @@index([name])
  @@map("sub_specializations")
}

model GovernmentForWorkers {
  workerProfileId String
  governmentId    String

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  government    Government    @relation(fields: [governmentId], references: [id], onDelete: Cascade)

  @@id([workerProfileId, governmentId])
  @@map("governments_for_workers")
}

model Government {
  id   String @id @default(uuid())
  name String

  workers GovernmentForWorkers[]
  users   User[]
  citys   City[]

  @@map("governments")
}

model City {
  id           String @id @default(uuid())
  governmentId String
  name         String

  users      User[]
  government Government @relation(fields: [governmentId], references: [id], onDelete: Cascade)

  @@map("cities")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum Role {
  USER
  ADMIN
}

enum Method {
  SMS
  WHATSAPP
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WorkerProfileStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Chat ────────────────────────────────────────────────────────────────────

enum ConversationRole {
  WORKER
  CLIENT
}

enum MessageType {
  TEXT
  IMAGE
}

model Conversation {
  id             String   @id @default(uuid())
  workerId       String
  clientId       String
  messageCounter Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  worker       User                      @relation("WorkerConversations", fields: [workerId], references: [id])
  client       User                      @relation("ClientConversations", fields: [clientId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@unique([workerId, clientId])
  @@map("conversations")
}

model ConversationParticipant {
  id                    String           @id @default(uuid())
  conversationId        String
  userId                String
  role                  ConversationRole
  lastReadMessageNumber Int              @default(0)
  createdAt             DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@unique([conversationId, role])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  messageNumber  Int
  content        String
  type           MessageType @default(TEXT)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@unique([conversationId, messageNumber])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
