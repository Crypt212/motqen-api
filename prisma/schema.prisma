generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  isRevoked  Boolean  @default(false)
  deviceId   String
  ipAddress  String?
  userAgent  String?
  lastUsedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id          String @id @default(uuid())
  phoneNumber String @unique

  firstName  String
  middleName String
  lastName   String

  profileImageUrl String?

  status AccountStatus @default(ACTIVE)
  role   Role          @default(USER)

  isOnline Boolean @default(true)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  sessions            Session[]
  workerProfile       WorkerProfile?
  clientProfile       ClientProfile?
  workerConversations Conversation[]            @relation("WorkerConversations")
  clientConversations Conversation[]            @relation("ClientConversations")
  conversations       ConversationParticipant[]
  sentMessages        Message[]

  @@map("users")
}

model ClientProfile {
  id     String @id @default(uuid())
  userId String @unique

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  orders    Order[]
  locations Location[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Location {
  id              String        @id @default(uuid())
  clientProfileId String
  governmentId    String
  cityId          String
  address         String
  addressNotes    String
  isMain          Boolean
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id])
  government      Government    @relation(fields: [governmentId], references: [id], onDelete: Cascade)
  city            City          @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model WorkerProfile {
  id     String @id @default(uuid())
  userId String @unique

  portfolioId       String? @unique
  experienceYears   Int     @default(0)
  isInTeam          Boolean @default(false)
  acceptsUrgentJobs Boolean @default(false)
  bio               String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  portfolio             Portfolio?
  verification          WorkerVerification?
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders                Order[]
  chosenSpecializations ChosenSpecialization[]
  workGovernments       Government[]
  badges                WorkerBadge[]

  @@map("worker_profiles")
}

model Order {
  id              String @id @default(uuid())
  clientProfileId String
  workerProfileId String

  rating      Float?
  price       Float
  description String?
  comment     String?
  status      OrderStatus @default(ORDERED)

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id])
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id])
}

model WorkerVerification {
  id              String @id @default(uuid())
  workerProfileId String @unique

  idWithPersonalImageUrl String
  idDocumentUrl          String
  reason                 String?
  status                 VerificationStatus @default(PENDING)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

model Portfolio {
  id              String @id @default(uuid())
  workerProfileId String @unique

  description String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  projectImages ProjectImage[]
  workerProfile WorkerProfile  @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
}

model ProjectImage {
  id          String   @id @default(uuid())
  portfolioId String   @map("projectId")
  imageUrl    String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model ChosenSpecialization {
  workerProfileId     String
  subSpecializationId String @unique
  specializationId    String

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  workerProfile     WorkerProfile     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  subSpecialization SubSpecialization @relation(fields: [subSpecializationId], references: [id], onDelete: Cascade)
  specialization    Specialization    @relation(fields: [specializationId], references: [id])

  @@id([workerProfileId, subSpecializationId])
  @@map("chosen_specializations")
}

model Specialization {
  id String @id @default(uuid())

  name     String
  nameAr   String
  category SpecializationCategory

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  subSpecializations SubSpecialization[]
  choosingWorkers    ChosenSpecialization[]

  @@index([name])
  @@map("specializations")
}

model SubSpecialization {
  id                   String @id @default(uuid())
  mainSpecializationId String

  name   String
  nameAr String

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  choosingWorkers    ChosenSpecialization[]
  mainSpecialization Specialization         @relation(fields: [mainSpecializationId], references: [id], onDelete: Cascade)

  @@index([name])
  @@map("sub_specializations")
}

model Government {
  id        String   @id @default(uuid())
  name      String
  nameAr    String
  long      String
  lat       String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  workers   WorkerProfile[]
  locations Location[]
  citys     City[]

  @@map("governments")
}

model City {
  id           String   @id @default(uuid())
  governmentId String
  name         String
  nameAr       String
  long         String
  lat          String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  locations  Location[]
  government Government @relation(fields: [governmentId], references: [id], onDelete: Cascade)

  @@map("cities")
}

model WorkerBadge {
  id              String   @id @default(uuid())
  workerProfileId String
  badgeType       String // e.g., "VERIFIED", "TOP_RATED", "TRUSTED"
  createdAt       DateTime @default(now())

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, badgeType])
  @@map("worker_badges")
}

enum OrderStatus {
  ORDERED
  APPROVED
  COMPLETED
  REVIEWED
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum Role {
  USER
  ADMIN
}

enum Method {
  SMS
  WHATSAPP
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WorkerProfileStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SpecializationCategory {
  ELECTRICITY
  PLUMBING
  AC
  CARPENTRY
  GENERALMAINTENANCE
  PAINTING
  CONSTRUCTION
  CLEANING
  INSTALLATION
  FURNITURETRANSPORT
  DRILLING
  ELECTRICALAPPLIANCES
  DEFAULTCATEGORY
}

// ─── Chat ────────────────────────────────────────────────────────────────────

enum ConversationRole {
  WORKER
  CLIENT
}

enum MessageType {
  TEXT
  IMAGE
}

model Conversation {
  id             String   @id @default(uuid())
  workerId       String
  clientId       String
  messageCounter Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  worker       User                      @relation("WorkerConversations", fields: [workerId], references: [id])
  client       User                      @relation("ClientConversations", fields: [clientId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@unique([workerId, clientId])
  @@map("conversations")
}

model ConversationParticipant {
  id                        String           @id @default(uuid())
  conversationId            String
  userId                    String
  role                      ConversationRole
  lastReadMessageNumber     Int              @default(0)
  lastReceivedMessageNumber Int              @default(0)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@unique([conversationId, role])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  messageNumber  Int
  content        String
  type           MessageType @default(TEXT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@unique([conversationId, messageNumber])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
