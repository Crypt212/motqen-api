generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  token             String   @unique
  isRevoked         Boolean  @default(false)
  deviceFingerprint String
  ipAddress         String?
  userAgent         String?
  lastUsedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OTP {
  id          String   @id @default(uuid())
  phoneNumber String
  hashedOTP   String
  updatedAt   DateTime
  createdAt   DateTime @default(now())
  method      Method

  @@unique([phoneNumber, method])
  @@map("OTP")
}

model User {
  id           String        @id @default(uuid())
  phoneNumber  String        @unique
  firstName    String
  lastName     String
  governmentId String?
  cityId       String?
  bio          String?
  profileImage String?
  status       AccountStatus @default(SUSPENDED)
  role          Role           @default(USER)

  city          City?          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  government    Government?    @relation(fields: [governmentId], references: [id], onDelete: Cascade)
  sessions      Session[]
  workerProfile WorkerProfile?
  clientProfile ClientProfile?

  @@map("users")
}

model ClientProfile {
  id     String @id @default(uuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model WorkerProfile {
  id                String  @id @default(uuid())
  userId            String  @unique
  experienceYears   Int
  isInTeam          Boolean
  acceptsUrgentJobs Boolean

  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chosenSpecializations ChosenSpecialization[]
  governments           GovernmentsForWorkers[]

  @@map("worker_profiles")
}

model ChosenSpecialization {
  workerProfileId  String
  specializationId String

  workerProfile            WorkerProfile             @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  specialization           Specialization            @relation(fields: [specializationId], references: [id], onDelete: Cascade)
  chosenSubSpecializations ChosenSubSpecialization[]

  @@id([workerProfileId, specializationId])
  @@map("chosen_specializations")
}

model ChosenSubSpecialization {
  workerProfileId        String
  subSpecializationId    String
  chosenSpecializationId String

  subSpecialization    SubSpecialization    @relation(fields: [subSpecializationId], references: [id], onDelete: Cascade)
  chosenSpecialization ChosenSpecialization @relation(fields: [workerProfileId, chosenSpecializationId], references: [workerProfileId, specializationId], onDelete: Cascade)

  @@id([chosenSpecializationId, subSpecializationId])
  @@unique([chosenSpecializationId, subSpecializationId])
  @@map("chosen_sub_specializations")
}

model Specialization {
  id   String @id @default(uuid())
  name String

  subSpecializations SubSpecialization[]
  chosenByWorker     ChosenSpecialization[]

  @@index([name])
  @@map("specializations")
}

model SubSpecialization {
  id                   String @id @default(uuid())
  name                 String
  mainSpecializationId String

  chosenByWorker     ChosenSubSpecialization[]
  mainSpecialization Specialization            @relation(fields: [mainSpecializationId], references: [id], onDelete: Cascade)

  @@index([name])
  @@map("sub_specializations")
}

model GovernmentsForWorkers {
  workerProfileId String
  governmentId    String

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  government    Government    @relation(fields: [governmentId], references: [id], onDelete: Cascade)

  @@id([workerProfileId, governmentId])
  @@map("governments_for_workers")
}

model Government {
  id   String @id @default(uuid())
  name String

  cities  City[]
  workers GovernmentsForWorkers[]
  users   User[]

  @@map("governments")
}

model City {
  id   String @id @default(uuid())
  name String
  governmentId String?

  users        User[]
  government   Government? @relation(fields: [governmentId], references: [id])

  @@map("cities")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum Role {
  USER
  ADMIN
}

enum Method {
  SMS
  WhatsApp
}
