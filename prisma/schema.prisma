generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  token             String   @unique
  isRevoked         Boolean  @default(false)
  deviceFingerprint String
  ipAddress         String?
  userAgent         String?
  lastUsedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OTP {
  id          String   @id @default(uuid())
  phoneNumber String
  hashedOTP   String
  updatedAt   DateTime
  createdAt   DateTime @default(now())
  method      Method

  @@unique([phoneNumber, method])
  @@map("OTP")
}

model User {
  id          String        @id @default(uuid())
  phoneNumber String        @unique
  firstName   String
  lastName    String
  government  String
  city        String
  bio         String?
  status      AccountStatus @default(INCOMPLETE)

  role       Role        @default(CLIENT)
  sessions   Session[]
  workerInfo WorkerInfo?

  @@map("users")
}

model WorkerInfo {
  id                      String  @id @default(uuid())
  userId                  String  @unique
  experienceYears         Int
  isInTeam                Boolean
  acceptsUrgentJobs       Boolean
  primarySpecializationId String

  secondarySpecializations SpecializationsForWorkers[]
  primarySpecialization    Specialization              @relation(fields: [primarySpecializationId], references: [id])
  user                     User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  governments              GovernmentsForWorkers[]

  @@map("worker_infos")
}

model SpecializationsForWorkers {
  workerInfoId     String
  specializationId String

  workerInfo     WorkerInfo     @relation(fields: [workerInfoId], references: [id], onDelete: Cascade)
  specialization Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([workerInfoId, specializationId])
  @@map("specializations_for_workers")
}

model GovernmentsForWorkers {
  workerInfoId String
  governmentId String

  workerInfo WorkerInfo @relation(fields: [workerInfoId], references: [id], onDelete: Cascade)
  government Government @relation(fields: [governmentId], references: [id], onDelete: Cascade)

  @@id([workerInfoId, governmentId])
  @@map("governments_for_workers")
}

model Specialization {
  id   String @id @default(uuid())
  name String

  secondaryWorkers SpecializationsForWorkers[]
  primaryWorkers   WorkerInfo[]

  @@index([name])
  @@map("specializations")
}

model Government {
  id      String                  @id @default(uuid())
  name    String
  workers GovernmentsForWorkers[]

  @@map("governments")
}

enum AccountStatus {
  INCOMPLETE
  ACTIVE
  SUSPENDED
  BANNED
}

enum Role {
  WORKER
  CLIENT
  ADMIN
  NOTCONFIRMED
  UNDEFINED
}

enum Method {
  SMS
  WhatsApp
}
