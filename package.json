{
  "name": "motqen-backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.js",
    "start": "node dist/server.js",
    "build": "npm run db:generate && tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --reporter=verbose src/**/*.test.ts",
    "test:integration": "vitest run --reporter=verbose src/**/*.integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "seed": "npm run seed:users && npm run seed:conversations && npm run seed:governments && npm run seed:specializations",
    "seed:users": "node seeds/samples/createTestUsers.js",
    "seed:conversations": "node ./seeds/samples/createConversations.js",
    "seed:governments": "node seeds/governments/createGovernments.js",
    "seed:specializations": "node seeds/specializations/createSpecializations.js",
    "lint": "eslint src --ext .ts,.js --fix",
    "format": "prettier --write src",
    "check:all": "npm run type-check && npm run lint && npm run format && npm run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.js": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.5",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "datauri": "^4.1.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.13.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "supertest": "^6.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "zod-prisma-types": "3.3.11"
  }
}
